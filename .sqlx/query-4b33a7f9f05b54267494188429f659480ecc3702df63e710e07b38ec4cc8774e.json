{
  "db_name": "PostgreSQL",
  "query": "SELECT\n            b.id,\n            b.publication_year,\n            b.title,\n            b.publisher,\n            b.volume_number,\n\n            g.id as genre_id,\n            g.name as genre_name,\n            g.note as genre_note,\n\n            a.id as author_id,\n            a.name as author_name,\n\n            s.id as series_id,\n            s.name as series_name,\n\n            b.place_id,\n            b.description,\n            b.created_at,\n            b.updated_at\n        FROM books b\n        INNER JOIN series s ON b.series_id = s.id\n        INNER JOIN authors a ON b.author_id = a.id\n        INNER JOIN genre g ON b.genre_id = g.id\n        WHERE b.id = $1",
